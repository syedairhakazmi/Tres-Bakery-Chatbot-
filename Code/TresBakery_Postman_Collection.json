              "path": ["session", "info", "nonexistent-session-id-12345"]
            },
            "description": "Request session info for a session that does not exist. Should return an error object."
          }
        },
        {
          "name": "POST /chat - Complaint Escalation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Escalation response contains contact info', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response).to.satisfy(function(s) {",
                  "        return s.includes('555') || s.includes('tresbakery.com') || s.includes('sorry');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"I want to complain about my order, the cake was completely wrong!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat",
              "host": ["{{base_url}}"],
              "path": ["chat"]
            },
            "description": "Send a complaint message. Policy requires Bella to respond with empathy and provide contact information."
          }
